{
    "compilerOptions": {
        "baseUrl": ".",
        "checkJs": true,
        "strict": true,
        "noImplicitAny": false,
        "strictNullChecks": true,
        "noUnusedLocals": true,
        "noUnusedParameters": false,
        "skipLibCheck": true,
        "paths": {
            "~/*": ["./*"],
            "@/*": ["./*"],
            "~~/*": ["./*"],
            "@@/*": ["./*"]
        }
    },
    "include": ["**/*.js", "**/*.vue"],
    "exclude": ["node_modules", ".nuxt", "dist"]
}
